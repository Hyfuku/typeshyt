# typeshyt – .htaccess für Shared Hosting (Docroot = Projektwurzel).
# Aufgaben: Basic Auth vor der ganzen Seite, alle Anfragen aus public/
# bedienen, sensible Dateien und Ordner sperren.

# ---------- Basic Auth ----------
# Greift nur, wenn die Passwortdatei existiert (= auf dem Server).
# Lokal im Docker-Container gibt es sie nicht -> kein Passwortschutz.
<IfFile /home/www/.htpasswd>
    AuthType Basic
    AuthName "typeshyt"
    AuthUserFile /home/www/.htpasswd
    Require valid-user
</IfFile>

# ---------- Sensible Dateien sperren ----------
<FilesMatch "\.(sql|md|ya?ml|yml|lock|scss|htpasswd)$|^(Dockerfile|\.env|\.env\.example|\.gitignore)$">
    Require all denied
</FilesMatch>

# ---------- Rewrite in den public/-Ordner ----------
RewriteEngine On

# Ordner mit Quellcode/Konfiguration hart sperren
RewriteRule ^(src|scss|bin|\.git)(/|$) - [F]

# Alles andere intern aus public/ bedienen (URL bleibt ohne /public/).
# Die Bedingung prüft den Pfad relativ zu diesem Ordner – funktioniert
# dadurch auch, wenn das Projekt in einem Unterordner der Domain liegt.
RewriteCond $1 !^public/
RewriteRule ^(.*)$ public/$1 [L]
